---
# Splunk Docker Compose configuration
# Generated by Ansible
#
# IMPORTANT: splunkd runs as the 'splunk' user (uid 41812) inside the official
# splunk/splunk image. The mounted etc/ and var/ volumes MUST be owned by 41812
# (the Proxmox VM cloud-init pre-owns /opt/splunk; if it has drifted:
# `chown -R 41812:41812 /opt/splunk`) or splunkd cannot read splunk.secret / passwd.
#
# RECOVERY (restart loop on "Get existing HEC token" 401): the image seeds the
# admin password from SPLUNK_PASSWORD only on FIRST boot, when etc/passwd is
# absent. etc/ is a persistent disk mount, so a later SPLUNK_PASSWORD change makes
# the entrypoint's Ansible 401 on its own REST API forever. Reset: stop the
# container, back up + remove /opt/splunk/etc/passwd, write
# etc/system/local/user-seed.conf with the current SPLUNK_PASSWORD, start. Full
# procedure: terraform-proxmox TROUBLESHOOTING.md -> "Splunk Container (VM 200)".

services:
  splunk:
    image: {{ splunk_docker_image }}
    hostname: {{ splunk_docker_hostname }}
    container_name: {{ splunk_docker_container_name }}
    environment:
      SPLUNK_START_ARGS: "--accept-license"
      SPLUNK_GENERAL_TERMS: "{{ splunk_docker_sgt_accept }}"
      SPLUNK_PASSWORD: "{{ splunk_docker_password }}"
      # HEC tokens are managed via inputs.conf (deployed by Ansible), not via a
      # SPLUNK_HEC_TOKEN env var, so the token is version-controlled instead of
      # generated per-boot. (The recurring "Get existing HEC token" 401 is a
      # persisted-password mismatch — see the RECOVERY note above — not this.)
      # SPLUNK_HOME_OWNERSHIP_ENFORCEMENT lets the entrypoint chown the mounted
      # volumes to the splunk user (41812) at startup.
      SPLUNK_HOME_OWNERSHIP_ENFORCEMENT: "true"
{% if splunk_docker_java_enabled %}
      JAVA_HOME: "{{ splunk_docker_java_container_home }}"
{% endif %}
    ports:
      - "{{ splunk_docker_web_port }}:8000"
      - "{{ splunk_docker_mgmt_bind }}:{{ splunk_docker_mgmt_port }}:8089"
      - "{{ splunk_docker_hec_port }}:8088"
    volumes:
      - {{ splunk_docker_var_dir }}:/opt/splunk/var
      - {{ splunk_docker_etc_dir }}:/opt/splunk/etc
{% if splunk_docker_java_enabled %}
      - {{ splunk_docker_java_home }}:{{ splunk_docker_java_container_home }}:ro
{% endif %}
    restart: unless-stopped
    # Healthcheck uses a lightweight HTTP GET against Splunk Web rather than the
    # splunk CLI (which would require auth and splunkd to be fully initialized).
    healthcheck:
{% if splunk_docker_web_ssl %}
      test: ["CMD-SHELL", "curl -sfk https://localhost:8000/en-US/account/login >/dev/null || exit 1"]
{% else %}
      test: ["CMD-SHELL", "curl -sf http://localhost:8000/en-US/account/login >/dev/null || exit 1"]
{% endif %}
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 180s
