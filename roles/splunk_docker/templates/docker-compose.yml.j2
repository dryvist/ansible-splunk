---
# Splunk Docker Compose configuration
# Generated by Ansible
#
# IMPORTANT: The splunk/splunk image runs its entrypoint as 'ansible' user,
# which then uses gosu to run Splunk processes as 'splunk' user (UID 41812).
# This is the intended design - do NOT change the container user.

services:
  splunk:
    image: {{ splunk_docker_image }}
    hostname: {{ splunk_docker_hostname }}
    container_name: {{ splunk_docker_container_name }}
    environment:
      SPLUNK_START_ARGS: "--accept-license"
      SPLUNK_GENERAL_TERMS: "{{ splunk_docker_sgt_accept | default('--accept-sgt-current-at-splunk-com') }}"
      SPLUNK_PASSWORD: "{{ splunk_docker_password }}"
      # HEC tokens are managed via inputs.conf (deployed by Ansible), not the
      # Docker entrypoint. Passing SPLUNK_HEC_TOKEN here causes the entrypoint's
      # internal Ansible to fail with 401 during bootstrap race conditions.
      # Let container entrypoint chown mounted volumes to splunk user at startup
      SPLUNK_HOME_OWNERSHIP_ENFORCEMENT: "true"
{% if splunk_docker_java_enabled %}
      JAVA_HOME: "{{ splunk_docker_java_container_home }}"
{% endif %}
    ports:
      - "{{ splunk_docker_web_port }}:8000"
      - "{{ splunk_docker_mgmt_bind }}:{{ splunk_docker_mgmt_port }}:8089"
      - "{{ splunk_docker_hec_port }}:8088"
    volumes:
      - {{ splunk_docker_var_dir }}:/opt/splunk/var
      - {{ splunk_docker_etc_dir }}:/opt/splunk/etc
{% if splunk_docker_java_enabled %}
      - {{ splunk_docker_java_home }}:{{ splunk_docker_java_container_home }}:ro
{% endif %}
    restart: unless-stopped
    # Healthcheck uses curl to avoid permission issues with splunk CLI
    # The CLI runs as 'ansible' user but needs to read files owned by 'splunk'
    healthcheck:
{% if splunk_docker_web_ssl %}
      test: ["CMD-SHELL", "curl -sfk https://localhost:8000/en-US/account/login >/dev/null || exit 1"]
{% else %}
      test: ["CMD-SHELL", "curl -sf http://localhost:8000/en-US/account/login >/dev/null || exit 1"]
{% endif %}
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 180s
