# {{ ansible_managed }} — managed by ansible-splunk ntp role.
# systemd-timesyncd: NTP= are the primary sources (internal Proxmox stratum-2),
# FallbackNTP= the public pool used only when the primary set is unreachable.
# Only the host token of each entry is kept (timesyncd takes bare hosts).
[Time]
{% if ntp_servers | length > 0 %}
NTP={{ ntp_servers | map('regex_replace', '\\s.*$', '') | join(' ') }}
{% endif %}
FallbackNTP={{ ntp_pools | map('regex_replace', '\\s.*$', '') | join(' ') }}
